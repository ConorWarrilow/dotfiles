#!/usr/bin/env bash
# Set up SSH key for GitHub and authenticate with GitHub CLI.
# If a GitHub PAT was provided at chezmoi init time, authentication
# is fully non-interactive. Otherwise falls back to --web device flow.
set -euo pipefail

info()    { printf '\033[1;34m[i] %s\033[0m\n' "$*"; }
success() { printf '\033[1;32m[✓] %s\033[0m\n' "$*"; }
warning() { printf '\033[1;33m[!] %s\033[0m\n' "$*"; }

KEY_NAME="git_${USER}_$(hostname)"
KEY_PATH="$HOME/.ssh/${KEY_NAME}"
GH_TOKEN="{{ .github_token }}"

# -------------------------------------------------------------------
# SSH directory setup
# -------------------------------------------------------------------
mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"
touch "$HOME/.ssh/known_hosts" "$HOME/.ssh/config"
chmod 600 "$HOME/.ssh/known_hosts" "$HOME/.ssh/config"

# -------------------------------------------------------------------
# Pre-populate known_hosts for GitHub (avoids host-verification prompts)
# -------------------------------------------------------------------
if ! grep -q "^github.com" "$HOME/.ssh/known_hosts" 2>/dev/null; then
  info "Adding GitHub to known hosts..."
  ssh-keyscan -t ed25519,rsa,ecdsa github.com >> "$HOME/.ssh/known_hosts" 2>/dev/null
  success "GitHub host keys added to known_hosts"
fi

# -------------------------------------------------------------------
# Generate SSH key if not present
# -------------------------------------------------------------------
if [[ ! -f "${KEY_PATH}.pub" ]]; then
  info "Generating SSH key: $KEY_NAME"
  ssh-keygen -t ed25519 -C "${USER}@$(hostname)" -f "$KEY_PATH" -N ""
  success "SSH key generated"

  if ! grep -q "Host github.com" "$HOME/.ssh/config"; then
    cat >> "$HOME/.ssh/config" <<EOF

Host github.com
  User git
  IdentityFile $KEY_PATH
  AddKeysToAgent yes
EOF
    success "SSH config updated"
  fi
else
  success "SSH key $KEY_NAME already exists"
fi

# -------------------------------------------------------------------
# GitHub CLI authentication
# -------------------------------------------------------------------
if ! command -v gh &>/dev/null; then
  warning "gh CLI not found — skipping GitHub auth. Install it first and re-run."
  echo ""
  echo "Your public key (add manually at https://github.com/settings/keys):"
  cat "${KEY_PATH}.pub"
  exit 0
fi

if gh auth status &>/dev/null; then
  success "Already authenticated with GitHub CLI"
elif [[ -n "$GH_TOKEN" ]]; then
  info "Authenticating with GitHub CLI via PAT..."
  echo "$GH_TOKEN" | gh auth login --hostname github.com --git-protocol ssh --with-token
  success "GitHub CLI authenticated"
else
  info "No PAT found — authenticating via browser..."
  gh auth login --hostname github.com --git-protocol ssh --web
fi

# -------------------------------------------------------------------
# Upload SSH key to GitHub if not already there
# -------------------------------------------------------------------
if ! gh ssh-key list 2>/dev/null | grep -q "$KEY_NAME"; then
  info "Uploading SSH key to GitHub..."
  gh ssh-key add "${KEY_PATH}.pub" --title "$KEY_NAME" && success "Key uploaded"
else
  success "SSH key already on GitHub"
fi

success "SSH + GitHub setup complete!"
