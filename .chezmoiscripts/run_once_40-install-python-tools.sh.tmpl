#!/usr/bin/env bash
# Install Python toolchain: uv (fast package manager), and optionally conda.
set -euo pipefail

info()    { printf '\033[1;34m[i] %s\033[0m\n' "$*"; }
success() { printf '\033[1;32m[✓] %s\033[0m\n' "$*"; }

# -------------------------------------------------------------------
# uv — fast Python package/project manager (all profiles)
# -------------------------------------------------------------------
if ! command -v uv &>/dev/null; then
  info "Installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  success "uv installed"
else
  success "uv already installed: $(uv --version)"
fi

# -------------------------------------------------------------------
# Miniconda — desktop and work profiles only
# -------------------------------------------------------------------
{{- if or .isDesktop .isWork }}
CONDA_DIR="$HOME/miniconda3"

if [[ -d "$CONDA_DIR" ]]; then
  success "Miniconda already installed at $CONDA_DIR"
else
  info "Installing Miniconda..."
  MINICONDA_URL="https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh"
  curl -fsSL "$MINICONDA_URL" -o /tmp/miniconda.sh
  bash /tmp/miniconda.sh -b -p "$CONDA_DIR"
  rm /tmp/miniconda.sh
  "$CONDA_DIR/bin/conda" init zsh
  success "Miniconda installed at $CONDA_DIR"
fi
{{- end }}
