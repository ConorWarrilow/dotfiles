#!/usr/bin/env bash
# Termux-specific additional setup.
{{- if not .isTermux }}
exit 0
{{- end }}
set -euo pipefail

info()    { printf '\033[1;34m[i] %s\033[0m\n' "$*"; }
success() { printf '\033[1;32m[✓] %s\033[0m\n' "$*"; }

info "Setting up Termux storage access..."
termux-setup-storage 2>/dev/null || true

info "Installing Termux API..."
pkg install -y termux-api 2>/dev/null || true

info "Setting zsh as default shell..."
chsh -s zsh 2>/dev/null || true

info "Installing Termux font (JetBrainsMono Nerd Font)..."
FONT_DIR="$HOME/.termux"
mkdir -p "$FONT_DIR"
if [[ ! -f "$FONT_DIR/font.ttf" ]]; then
  curl -fsSL \
    "https://github.com/ryanoasis/nerd-fonts/raw/master/patched-fonts/JetBrainsMono/Ligatures/Regular/JetBrainsMonoNerdFontMono-Regular.ttf" \
    -o "$FONT_DIR/font.ttf"
  termux-reload-settings
  success "Font installed"
fi

success "Termux setup complete!"
