#!/usr/bin/env bash
# Install desktop applications: Kitty, VS Code, Obsidian, Docker.
# Desktop profile only.
{{- if not .isDesktop }}
exit 0
{{- end }}
set -euo pipefail

info()    { printf '\033[1;34m[i] %s\033[0m\n' "$*"; }
success() { printf '\033[1;32m[✓] %s\033[0m\n' "$*"; }
warning() { printf '\033[1;33m[!] %s\033[0m\n' "$*"; }

# -------------------------------------------------------------------
# Kitty terminal
# -------------------------------------------------------------------
if ! command -v kitty &>/dev/null; then
  info "Installing Kitty terminal..."
  curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin
  # Make kitty accessible on PATH
  mkdir -p "$HOME/.local/bin"
  ln -sf "$HOME/.local/kitty.app/bin/kitty" "$HOME/.local/bin/kitty"
  ln -sf "$HOME/.local/kitty.app/bin/kitten" "$HOME/.local/bin/kitten"
  # Desktop integration
  cp "$HOME/.local/kitty.app/share/applications/kitty.desktop" "$HOME/.local/share/applications/" 2>/dev/null || true
  success "Kitty installed"
else
  success "Kitty already installed: $(kitty --version)"
fi

# -------------------------------------------------------------------
# VS Code
# -------------------------------------------------------------------
if ! command -v code &>/dev/null; then
  info "Installing VS Code..."
  curl -fsSL "https://code.visualstudio.com/sha/download?build=stable&os=linux-deb-x64" \
    -o /tmp/vscode.deb
  sudo apt-get install -y /tmp/vscode.deb
  rm /tmp/vscode.deb
  success "VS Code installed"
else
  success "VS Code already installed: $(code --version | head -1)"
fi

# -------------------------------------------------------------------
# Obsidian
# -------------------------------------------------------------------
if ! command -v obsidian &>/dev/null && ! ls "$HOME/.local/share/applications/obsidian"* &>/dev/null 2>&1; then
  info "Installing Obsidian..."
  OBS_VERSION="1.7.7"
  curl -fsSL "https://github.com/obsidianmd/obsidian-releases/releases/download/v${OBS_VERSION}/obsidian_${OBS_VERSION}_amd64.deb" \
    -o /tmp/obsidian.deb
  sudo apt-get install -y /tmp/obsidian.deb
  rm /tmp/obsidian.deb
  success "Obsidian installed"
else
  success "Obsidian already installed"
fi

# -------------------------------------------------------------------
# Docker
# -------------------------------------------------------------------
if ! command -v docker &>/dev/null; then
  info "Installing Docker..."
  sudo apt-get install -y ca-certificates curl gnupg lsb-release
  sudo mkdir -p /etc/apt/keyrings
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
    | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
    https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
    | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
  sudo apt-get update -qq
  sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
  sudo usermod -aG docker "$USER"
  sudo systemctl enable docker.service containerd.service
  success "Docker installed"
else
  success "Docker already installed: $(docker --version)"
fi
