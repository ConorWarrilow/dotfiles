#!/usr/bin/env bash
# Install Rust via rustup and common Cargo tools.
# Skipped on Termux (use pkg install rust instead).
{{ if .isTermux -}}
exit 0
{{- end }}
set -euo pipefail

info()    { printf '\033[1;34m[i] %s\033[0m\n' "$*"; }
success() { printf '\033[1;32m[✓] %s\033[0m\n' "$*"; }
warning() { printf '\033[1;33m[!] %s\033[0m\n' "$*"; }

export CARGO_HOME="${CARGO_HOME:-$HOME/.cargo}"
export RUSTUP_HOME="${RUSTUP_HOME:-$HOME/.rustup}"

if command -v rustup &>/dev/null || [[ -f "$RUSTUP_HOME/settings.toml" ]]; then
  # Rustup is already present; just make sure the env is sourced.
  # (rustc may not be on PATH yet if this is a fresh shell.)
  [[ -f "$CARGO_HOME/env" ]] && source "$CARGO_HOME/env"
  success "Rust already installed: $(rustc --version 2>/dev/null || echo 'env not yet in PATH')"
else
  info "Installing Rust via rustup..."
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
  source "$CARGO_HOME/env"
  success "Rust installed: $(rustc --version)"
fi

source "$CARGO_HOME/env"

info "Installing Rust components..."
rustup component add rustfmt clippy llvm-tools-preview

info "Installing Cargo tools..."

# Core CLI replacements (fast, worth waiting for)
for tool in \
  "eza"         \
  "bat"         \
  "fd-find"     \
  "ripgrep"     \
  "zoxide"      \
  "just"        \
  "vivid"
do
  crate="${tool%% *}"
  if ! cargo install --list | grep -q "^$crate "; then
    info "  installing $crate..."
    cargo install "$crate" || warning "  failed to install $crate (non-fatal)"
  else
    success "  $crate already installed"
  fi
done

success "Rust environment ready: $(rustc --version)"
