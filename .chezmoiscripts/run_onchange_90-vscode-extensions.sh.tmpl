#!/usr/bin/env bash
# Install VS Code extensions listed in extensions.txt.
# Runs whenever the extensions list changes (run_onchange_).
{{- if not .isDesktop }}
exit 0
{{- end }}
set -euo pipefail

info()    { printf '\033[1;34m[i] %s\033[0m\n' "$*"; }
success() { printf '\033[1;32m[✓] %s\033[0m\n' "$*"; }

if ! command -v code &>/dev/null; then
  echo "VS Code not installed — skipping extension install" >&2
  exit 0
fi

# Extensions list hash embedded in script body so run_onchange_ fires on list changes:
# {{ include (joinPath .chezmoi.sourceDir "dot_config/Code/User/extensions.txt") | sha256sum }}

info "Installing VS Code extensions..."
EXTENSIONS_FILE="{{ joinPath .chezmoi.sourceDir "dot_config/Code/User/extensions.txt" }}"

while IFS= read -r ext || [[ -n "$ext" ]]; do
  [[ -z "$ext" || "$ext" == \#* ]] && continue
  code --install-extension "$ext" --force
done < "$EXTENSIONS_FILE"

success "VS Code extensions installed!"
