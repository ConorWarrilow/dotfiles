#!/usr/bin/env bash
# Install Oh My Zsh into ~/.config/.oh-my-zsh (respects XDG)
# ZSH_CUSTOM is set to ~/.config/zsh/custom in .zshrc
set -euo pipefail

info()    { printf '\033[1;34m[i] %s\033[0m\n' "$*"; }
success() { printf '\033[1;32m[✓] %s\033[0m\n' "$*"; }

OMZ_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/.oh-my-zsh"

if [[ -d "$OMZ_DIR" ]]; then
  success "Oh My Zsh already installed at $OMZ_DIR"
  exit 0
fi

info "Installing Oh My Zsh to $OMZ_DIR ..."
ZSH="$OMZ_DIR" sh -c \
  "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" \
  "" --unattended --keep-zshrc

success "Oh My Zsh installed!"

# -------------------------------------------------------------------
# Set zsh as the default shell
# -------------------------------------------------------------------
ZSH_PATH="$(command -v zsh 2>/dev/null || true)"
if [[ -n "$ZSH_PATH" ]]; then
  # Ensure zsh is listed in /etc/shells
  if ! grep -qx "$ZSH_PATH" /etc/shells 2>/dev/null; then
    info "Registering $ZSH_PATH in /etc/shells..."
    echo "$ZSH_PATH" | sudo tee -a /etc/shells > /dev/null
  fi
  if [[ "$SHELL" != "$ZSH_PATH" ]]; then
    info "Changing default shell to zsh..."
    sudo chsh -s "$ZSH_PATH" "$USER"
    success "Default shell set to zsh (takes effect on next login)"
  else
    success "Default shell is already zsh"
  fi
fi
