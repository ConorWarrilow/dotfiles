ff(){
    fdfind --type f \
        --exclude '.git' \
        --exclude 'node_modules' \
        --exclude '.vscode' \
        --exclude 'build' \
        --exclude 'dist' \
        --exclude '__pycache__' \
        --exclude '.cache' \
        --exclude '*.o' \
        --exclude '*.so' \
        --exclude '*.a' \
        --exclude '*.exe' \
        --exclude '*.dll' \
        --exclude '.conda' \
        --exclude 'miniconda3' \
        --exclude '*.jpg' \
        --exclude 'snap' \
        --exclude '*.bin' \
        --exclude '*.class' \
        --exclude '*.jar' \
        --exclude '*.pyc' \
        --exclude '*.pyo' \
        --exclude '*.log' \
        --exclude '*.tmp' \
        --exclude '.DS_Store' \
        --exclude 'Thumbs.db' \
        --exclude node_modules --exclude build --exclude dist \
        | fzf --height=100% \
            --preview='batcat --style=numbers --color=always --line-range :500 {} 2>/dev/null || file {} || echo "Cannot preview"' \
            --preview-window=right:60% \
            --bind 'enter:execute(${EDITOR:-nvim} {})'
}

ff
